{
  "name": "hymn-presenter",
  "version": "1.0.1",
  "description": "A hymn presenter app built for New Hope Universal Church (NHUC)",
  "author": {
    "name": "Aaron Katey Kudadjie",
    "github": "https://github.com/Adehwam21/"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "sql.js": "^1.11.0"
  },
  "build": {
    "compression": "maximum",
    "appId": "com.nhuc.hymnprojector",
    "productName": "NHUC Hymn Presenter",
    "icon": "assets/icons/logo-transparent.ico",
    "publish": {
      "provider": "github",
      "owner": "Adehwam21",
      "repo": "hymn-presenter"
    },
    "extraResources": [
      {
        "from": "data/mhb_clean.db",
        "to": "mhb_clean.db"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/logo-transparent.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/logo-transparent.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hymn Presenter"
    },
    "files": [
      "**/*",
      "!node_modules/electron*"
    ]
  }
}